import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { QRCodeSVG } from 'qrcode.react';

const courses = [
  { id: 1, name: 'Software Engineering', code: 'SWE3090', students: 45 },
  { id: 2, name: 'Database Systems', code: 'BIS3050', students: 38 },
  { id: 3, name: 'Business Application Dev', code: 'IST3010', students: 50 },
];

// SVG Icons
const PlayIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={{ marginRight: '6px', verticalAlign: 'middle' }}><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
);
const StopIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={{ marginRight: '6px', verticalAlign: 'middle' }}><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
);
const ClockIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={{ marginRight: '6px', verticalAlign: 'middle' }}><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
);

export default function LecturerDashboard() {
  const navigate = useNavigate();
  const [user, setUser] = useState(null);
  const [activeSession, setActiveSession] = useState(null);
  const [timeLeft, setTimeLeft] = useState(7);
  const [qrData, setQrData] = useState('');
  const [anomalies, setAnomalies] = useState([]);

  // 1. Check Authentication on Load
  useEffect(() => {
    const storedUser = localStorage.getItem('user');
    if (!storedUser) {
      navigate('/');
    } else {
      setUser(JSON.parse(storedUser));
      // --- STEP 2 GOES HERE: Fetch the security logs ---
      const fetchAnomalies = async () => {
        try {
          const response = await fetch('/api/sessions/anomalies');
          if (response.ok) {
            const data = await response.json();
            setAnomalies(data);
          }
        } catch (err) {
          console.error("Failed to fetch anomalies", err);
        }
      };

      fetchAnomalies(); // Trigger the fetch
    }
  }, [navigate]);


  // 2. The Real 7-Second Dynamic QR Code Engine linking to the Database
  useEffect(() => {
    let rotationInterval;
    let countdownInterval;

    if (activeSession && activeSession.dbSessionId) {
      generateAndSaveToken(activeSession.code, activeSession.dbSessionId);

      rotationInterval = setInterval(() => {
        generateAndSaveToken(activeSession.code, activeSession.dbSessionId);
        setTimeLeft(7);
      }, 7000);

      countdownInterval = setInterval(() => {
        setTimeLeft((prev) => (prev > 0 ? prev - 1 : 7));
      }, 1000);
    }

    return () => {
      clearInterval(rotationInterval);
      clearInterval(countdownInterval);
    };
  }, [activeSession]);

  // --- API CALLS ---

  const handleStartSession = async (course) => {
    try {
      const response = await fetch('http://localhost:5000/api/sessions/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ courseId: course.code, lecturerId: user.user_id })
      });
      const data = await response.json();
      
      if (response.ok) {
        setActiveSession({ ...course, dbSessionId: data.session_id });
      }
    } catch (err) {
      console.error("Failed to start session on server", err);
    }
  };

  const generateAndSaveToken = async (courseCode, dbSessionId) => {
    const secureToken = crypto.randomUUID() + '-' + Date.now();
    const qrPayload = JSON.stringify({ course: courseCode, token: secureToken, timestamp: Date.now() });
    
    setQrData(qrPayload);

    try {
      await fetch('http://localhost:5000/api/sessions/rotate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: dbSessionId, token: secureToken })
      });
    } catch (err) {
      console.error("Failed to save rotating token", err);
    }
  };

  const handleEndSession = async () => {
    try {
      await fetch('/api/sessions/end', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: activeSession.dbSessionId })
      });
      setActiveSession(null);
    } catch (err) {
      console.error("Failed to end session", err);
    }
  };

  const handleLogout = () => {
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    navigate('/');
  };

  if (!user) return null;

  return (
    <div style={styles.layout}>
      {/* SIDEBAR */}
      <aside style={styles.sidebar}>
        <div style={styles.sidebarHeader}>
          <h2 style={styles.logo}>MySignInApp</h2>
        </div>
        <nav style={styles.nav}>
          <p style={styles.activeNavLink}>Dashboard</p>
          <p style={styles.navLink}>Sessions</p>
          <p style={styles.navLink}>Reports</p>
        </nav>
        <div style={styles.sidebarFooter}>
          <div style={styles.profileBox}>
            <p style={{ fontWeight: 'bold', margin: 0 }}>Prof. {user.last_name || 'Okanda'}</p>
            <p style={{ fontSize: '0.8rem', color: '#ccc', margin: 0 }}>Lecturer</p>
          </div>
          <button aria-label="Logout" onClick={handleLogout} style={styles.logoutBtn}>Logout</button>
        </div>
      </aside>

      {/* MAIN CONTENT */}
      <main style={styles.main}>
        <header style={styles.header}>
          <div style={{...styles.greetingBox, borderLeft: '5px solid #1a237e'}}>
            <h3 style={{ margin: '0 0 0.5rem 0', color: '#333' }}>Welcome back, Prof. {user.last_name || 'Okanda'}.</h3>
            <p style={{ color: '#666', margin: 0 }}>Manage your courses and live attendance sessions below.</p>
          </div>
        </header>
         {/* STEP 3: SECURITY ANOMALY FEED */}
      {anomalies.length > 0 && (
        <div style={{ background: '#ffebee', borderLeft: '5px solid #d32f2f', padding: '1rem', marginBottom: '2rem', borderRadius: '4px' }}>
          <h3 style={{ color: '#d32f2f', marginTop: 0 }}>🚨 Security Alerts (Recent)</h3>
          <ul style={{ listStyleType: 'none', padding: 0, margin: 0 }}>
            {anomalies.map((log, index) => (
              <li key={index} style={{ marginBottom: '0.5rem', fontSize: '0.9rem', color: '#424242' }}>
                <strong>{new Date(log.created_at).toLocaleTimeString()}:</strong> {log.flag_reason} 
                <br />
                <span style={{ fontSize: '0.8rem', color: '#757575' }}>Attempted by ID: {log.attempted_student_id}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

        {activeSession ? (
          <section aria-label="Active attendance session" style={styles.activeSessionCard}>
            <div style={styles.sessionHeader}>
              <div>
                <span style={styles.liveBadge}>
                  <ClockIcon /> LIVE SESSION
                </span>
                <h4 style={{ margin: '0.5rem 0 0', fontSize: '1.2rem', color: '#222' }}>{activeSession.code}: {activeSession.name}</h4>
              </div>
              <button aria-label="End session" onClick={handleEndSession} style={styles.endButton}>
                <StopIcon /> End Session
              </button>
            </div>

            <div style={styles.sessionBody}>
              <div style={styles.qrContainer}>
                <div style={styles.qrBox} aria-label="QR Code display area">
                  <QRCodeSVG 
                    value={qrData} 
                    size={200} 
                    bgColor={"#ffffff"}
                    fgColor={"#1a237e"}
                    level={"Q"}
                    includeMargin={false}
                  />
                </div>
                <p style={styles.timerText}>
                  Code rotates in <strong style={{ color: '#1a237e', fontSize: '1.2rem' }}>{timeLeft}s</strong>
                </p>
                <p style={{ fontSize: '0.85rem', color: '#666' }}>Dynamic encryption enabled to prevent sharing</p>
              </div>

              <div style={styles.statsContainer}>
                <div style={styles.statBox}>
                  <p style={{ margin: 0, color: '#666', fontWeight: '600' }}>Live Attendance</p>
                  <h2 style={{ margin: '0.5rem 0 0', color: '#1a237e', fontSize: '2.5rem' }}>0 / {activeSession.students}</h2>
                  <p style={{ margin: 0, fontSize: '0.85rem', color: '#888' }}>Students Present</p>
                </div>
              </div>
            </div>
          </section>
        ) : (
          <section style={styles.courseGrid}>
            <h4 style={{ margin: '0 0 0.5rem 0', color: '#333', width: '100%' }}>My Courses</h4>
            {courses.map(course => (
              <div key={course.id} style={styles.card}>
                <div>
                  <strong style={{ fontSize: '1.1rem', color: '#222' }}>{course.name}</strong>
                  <p style={styles.code}>{course.code} • {course.students} Enrolled</p>
                </div>
                <button
                  aria-label={`Start attendance session for ${course.name}`}
                  style={styles.startBtn}
                  onClick={() => handleStartSession(course)}
                >
                  <PlayIcon /> Create Session
                </button>
              </div>
            ))}
          </section>
        )}
      </main>
    </div>
  );
}

