const express = require('express');
const bcrypt = require('bcrypt');
const jwt = require('jsonwebtoken');
const crypto = require('crypto'); // Built-in Node library for generating IDs
const pool = require('../db');

const router = express.Router();

// 1. REGISTER ROUTE
router.post('/register', async (req, res) => {
  try {
    const { firstName, lastName, email, password, role } = req.body;

    // Check if user already exists
    const userExists = await pool.query('SELECT * FROM users WHERE email = $1', [email]);
    if (userExists.rows.length > 0) {
      return res.status(401).json({ error: 'User already exists' });
    }

    // Hash the password securely
    const saltRounds = 10;
    const salt = await bcrypt.genSalt(saltRounds);
    const bcryptPassword = await bcrypt.hash(password, salt);

    // Generate a unique user ID
    const userId = crypto.randomUUID();

    // Insert new user into the database
    const newUser = await pool.query(
      'INSERT INTO users (user_id, first_name, last_name, email, password_hash, role) VALUES ($1, $2, $3, $4, $5, $6) RETURNING user_id, first_name, last_name, email, role',
      [userId, firstName, lastName, email, bcryptPassword, role]
    );

    // Generate JWT Token
    const token = jwt.sign({ user_id: newUser.rows[0].user_id, role: newUser.rows[0].role }, process.env.JWT_SECRET, { expiresIn: '10h' });

    res.json({ token, user: newUser.rows[0] });
  } catch (err) {
    console.error(err.message);
    res.status(500).json({ error: 'Server Error during registration' });
  }
});

// 2. LOGIN ROUTE
router.post('/login', async (req, res) => {
  try {
    const { email, password } = req.body;

    // Check if user exists
    const user = await pool.query('SELECT * FROM users WHERE email = $1', [email]);
    if (user.rows.length === 0) {
      return res.status(401).json({ error: 'Invalid Credentials' });
    }

    // Check if password matches the hashed password in database
    const validPassword = await bcrypt.compare(password, user.rows[0].password_hash);
    if (!validPassword) {
      return res.status(401).json({ error: 'Invalid Credentials' });
    }

    // Generate JWT Token
    const token = jwt.sign({ user_id: user.rows[0].user_id, role: user.rows[0].role }, process.env.JWT_SECRET, { expiresIn: '10h' });

    // Send back token and user info (excluding password)
    res.json({ 
      token, 
      user: { 
        user_id: user.rows[0].user_id, 
        first_name: user.rows[0].first_name, 
        last_name: user.rows[0].last_name, 
        email: user.rows[0].email, 
        role: user.rows[0].role 
      } 
    });
  } catch (err) {
    console.error(err.message);
    res.status(500).json({ error: 'Server Error during login' });
  }
});

module.exports = router;
