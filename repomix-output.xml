       WHERE s.lecturer_id = $1 AND s.status = 'Closed'
       GROUP BY s.session_id, s.course_id, c.course_name, s.start_time, s.end_time, s.status
       ORDER BY s.start_time DESC
       LIMIT 30`,
      [lecturerId]
